---
// ABOUTME: Homepage. Stack: Hero → CuratedPicks ("What I'd point you at right now") → LatestWriting.
// ABOUTME: Reading depth is the north star; the page exists to surface the post the reader clicks first AND the one they click second.

import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/home/Hero.astro';
import CuratedPicks from '../components/home/CuratedPicks.astro';
import LatestWriting from '../components/home/LatestWriting.astro';
import { getCollection } from 'astro:content';

const allPosts = (await getCollection('blog', ({ data }) => !data.draft)).sort(
  (a, b) => +b.data.date - +a.data.date,
);

const latest = allPosts.slice(0, 10);

// Curated picks — handpicked, voice-framed, refreshed when something better lands.
// Slugs are the entry ids from src/content/blog (filename without .mdx).
const picks = [
  {
    slug: '2026-02-a-gsd-system-for-claude-code',
    framing: 'If you’re new here',
  },
  {
    slug: '2022-03-manager-weekly-newsletter',
    framing: 'If you manage people',
  },
  {
    slug: '2020-05-career-change',
    framing: 'The one I’m proudest of',
  },
];

const now =
  'Trying to figure out where AI-assisted engineering management ends and craft begins. Re-reading Julie Zhuo. Skeptical of every productivity hack the team forwards me.';

const updated = 'June 2026';
---

<BaseLayout current="home">
  <Hero />
  <CuratedPicks now={now} updated={updated} picks={picks} />
  <LatestWriting posts={latest} />
</BaseLayout>
