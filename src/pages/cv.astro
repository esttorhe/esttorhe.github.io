---
// ABOUTME: /cv/ — truncated web view of the CV (rendering + base styles shared with /cv/print/ via CvBody + src/styles/cv.css).
// ABOUTME: PDF download link surfaces /cv/esteban-torres-cv.pdf, generated from /cv/print/ via scripts/build-cv-pdf.mjs.

import { access } from 'node:fs/promises';
import { constants as FS } from 'node:fs';
import { fileURLToPath } from 'node:url';
import BaseLayout from '../layouts/BaseLayout.astro';
import CvBody from '../components/cv/CvBody.astro';

const pdfRelPath = '/cv/esteban-torres-cv.pdf';
const pdfDiskPath = fileURLToPath(new URL('../../public' + pdfRelPath, import.meta.url));

let pdfAvailable = false;
try {
  await access(pdfDiskPath, FS.R_OK);
  pdfAvailable = true;
} catch {
  pdfAvailable = false;
}
---

<BaseLayout
  title="CV — Esteban Torres"
  bareTitle
  description="Engineering leadership CV — Head of Engineering, Engineering Manager, iOS/Platform roles across Zenjob, Spotify, SoundCloud, and earlier."
  current="cv"
>
  <article class="cv reveal">
    {
      pdfAvailable && (
        <a class="cv__pdf-floating" href={pdfRelPath} download>
          <span>Download full PDF</span>
          <span aria-hidden="true">↓</span>
        </a>
      )
    }
    <CvBody />
    {
      pdfAvailable && (
        <footer class="cv__bottom">
          <a class="cv__pdf-button" href={pdfRelPath} download>
            <span>Download CV (PDF)</span>
            <span aria-hidden="true">↓</span>
          </a>
          <p class="cv__bottom-note tabular">
            Full version — earlier roles, projects, and education included.
          </p>
        </footer>
      )
    }
  </article>
</BaseLayout>

<style>
  /* PDF download — single affordance, repositioned by viewport.
     Below 1200px: inline at the top of the CV column, bordered mono pill.
     At ≥1200px: floats top-right of the column. Hidden in print. */
  .cv__pdf-floating {
    display: inline-flex;
    align-items: baseline;
    gap: 0.4ch;
    margin: 0 0 var(--space-md);
    padding: 0.3rem 0.6rem;
    border: 1px solid var(--rule);
    border-radius: var(--radius-sm);
    background: var(--surface);
    font-family: var(--font-mono);
    font-size: var(--text-meta);
    color: var(--ink);
    text-decoration: none;
    transition:
      border-color var(--duration-fast) var(--ease-out-quart),
      background var(--duration-fast) var(--ease-out-quart),
      color var(--duration-fast) var(--ease-out-quart);
  }

  .cv__pdf-floating:hover,
  .cv__pdf-floating:focus-visible {
    border-color: var(--accent);
    background: var(--bg);
    color: var(--accent-ink);
    outline: none;
  }

  @media (min-width: 1200px) {
    .cv__pdf-floating {
      position: absolute;
      top: 0;
      right: 0;
      margin: 0;
    }
  }

  /* Bottom of the page — a more substantial repeat of the same affordance.
     Bigger hit target than the top pill, with a one-line note explaining
     what 'full' means since the web view drops earlier roles + projects. */
  .cv__bottom {
    margin: var(--space-xl) 0 0;
    padding-top: var(--space-lg);
    border-top: 1px solid var(--rule);
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: var(--space-xs);
  }

  .cv__pdf-button {
    display: inline-flex;
    align-items: baseline;
    gap: 0.5ch;
    padding: 0.7rem 1.1rem;
    background: var(--ink);
    color: var(--bg);
    font-family: var(--font-mono);
    font-size: var(--text-small);
    text-decoration: none;
    border-radius: var(--radius-sm);
    transition:
      background var(--duration-fast) var(--ease-out-quart),
      transform var(--duration-fast) var(--ease-out-quart);
  }

  .cv__pdf-button:hover,
  .cv__pdf-button:focus-visible {
    background: var(--accent-ink);
    color: var(--bg);
    outline: none;
    transform: translateY(-1px);
  }

  .cv__bottom-note {
    margin: 0;
    font-family: var(--font-mono);
    font-size: var(--text-meta);
    color: var(--ink-muted);
  }

  @media print {
    .cv__bottom {
      display: none !important;
    }
  }
</style>
