---
// ABOUTME: Shared CV rendering — reads external/cv/cv.md and delegates to cvRender.ts for either flat (PDF source) or grouped-narrative (web).
// ABOUTME: Used by /cv/ (grouped) and /cv/print/ (flat, PDF source). Styles live in src/styles/cv.css.

import '../../styles/cv.css';
import { readFile } from 'node:fs/promises';
import { resolve } from 'node:path';
import { renderFlatCv, renderGroupedCv, escapeHtml } from '../../lib/cvRender';

interface Props {
  /** When true, render the whole cv.md flat (for the print/PDF surface). Default false uses the grouped narrative layout. */
  full?: boolean;
}

const { full = false } = Astro.props;

const cvPath = resolve(process.cwd(), 'external/cv/cv.md');

let html = '';
try {
  const source = await readFile(cvPath, 'utf8');
  if (full) {
    html = await renderFlatCv(source);
  } else {
    const result = await renderGroupedCv(source);
    html = result.html;
  }
} catch (err) {
  const msg = err instanceof Error ? err.message : String(err);
  html = [
    '<div class="cv__fallback">',
    '<h1>CV</h1>',
    '<p>The CV is temporarily unavailable. Run <code>git submodule update --init --recursive</code> and rebuild.</p>',
    `<p class="cv__fallback-diagnostic"><small>${escapeHtml(msg)}</small></p>`,
    '</div>',
  ].join('');
}
---

<div class="cv__rendered" set:html={html} />
