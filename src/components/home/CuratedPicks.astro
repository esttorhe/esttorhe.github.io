---
// ABOUTME: "What I'd point you at right now" — the reading-depth scaffold.
// ABOUTME: Combines a dated now-line with three voice-framed pinned post picks.

import { getEntry } from 'astro:content';

interface PickInput {
  slug: string;
  framing: string;
}

interface Props {
  /** Short dated note about what's preoccupying you. 1–2 lines. */
  now: string;
  /** Three pinned post picks. Each `slug` matches an entry id in src/content/blog/. */
  picks: PickInput[];
  /** Date the picks/now line were last touched. */
  updated: string;
}

const { now, picks, updated } = Astro.props;

// Resolve each pick from the content collection.
const resolved = (
  await Promise.all(
    picks.map(async (p) => {
      const entry = await getEntry('blog', p.slug);
      if (!entry) return null;
      const date = new Date(entry.data.date);
      const year = String(date.getFullYear());
      const month = String(date.getMonth() + 1).padStart(2, '0');
      const titleSlug = entry.id.replace(/^\d{4}-\d{2}-/, '').replace(/\.mdx?$/, '');
      return {
        framing: p.framing,
        title: entry.data.title,
        href: `/${year}/${month}/${titleSlug}/`,
        category: entry.data.category,
        year,
      };
    }),
  )
).filter((p): p is NonNullable<typeof p> => p !== null);
---

<section class="curated reveal" aria-labelledby="curated-heading">
  <header class="curated__header">
    <h2 id="curated-heading" class="curated__title">What I'd point you at right now</h2>
    <p class="curated__updated">
      <span class="curated__updated-label">Updated</span>
      <time>{updated}</time>
    </p>
  </header>

  <p class="curated__now">{now}</p>

  <ul class="curated__picks reveal-stagger">
    {
      resolved.map((pick, i) => (
        <li class="curated__pick" style={`--i: ${i}`}>
          <a href={pick.href} class="curated__link">
            <span class="curated__framing">{pick.framing}</span>
            <span class="curated__pointer" aria-hidden="true">
              →
            </span>
            <span class="curated__pick-title">{pick.title}</span>
            <span class="curated__pick-meta tabular">
              {pick.category} · {pick.year}
            </span>
          </a>
        </li>
      ))
    }
  </ul>
</section>

<style>
  .curated {
    margin-bottom: var(--space-2xl);
    padding: var(--space-lg) 0;
    border-top: 1px solid var(--rule);
    border-bottom: 1px solid var(--rule);
  }

  .curated__header {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: var(--space-sm);
    margin-bottom: var(--space-md);
  }

  .curated__title {
    font-size: var(--text-h3);
    font-weight: 600;
    color: var(--ink);
    margin: 0;
  }

  .curated__updated {
    font-family: var(--font-mono);
    font-size: var(--text-meta);
    color: var(--ink-muted);
    margin: 0;
  }

  .curated__updated-label::after {
    content: ' ';
  }

  .curated__now {
    font-size: var(--text-lead);
    color: var(--ink);
    line-height: 1.5;
    margin: 0 0 var(--space-lg);
    max-width: 38rem;
    text-wrap: pretty;
  }

  .curated__picks {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .curated__pick {
    margin: 0;
  }

  .curated__link {
    display: grid;
    grid-template-columns: minmax(13rem, max-content) auto 1fr max-content;
    grid-template-areas: 'framing pointer title meta';
    column-gap: var(--space-sm);
    row-gap: 0.25rem;
    align-items: baseline;
    padding: 0.625rem 0;
    text-decoration: none;
    color: var(--ink);
    border-bottom: 1px solid transparent;
    transition:
      border-color var(--duration-fast) var(--ease-out-quart),
      color var(--duration-fast) var(--ease-out-quart);
  }

  .curated__link:hover,
  .curated__link:focus-visible {
    border-color: var(--rule-strong);
    outline: none;
  }

  .curated__link:hover .curated__pointer,
  .curated__link:focus-visible .curated__pointer {
    transform: translateX(0.25rem);
    color: var(--accent);
  }

  .curated__link:hover .curated__pick-title,
  .curated__link:focus-visible .curated__pick-title {
    color: var(--accent-ink);
  }

  .curated__framing {
    grid-area: framing;
    font-family: var(--font-mono);
    font-size: var(--text-meta);
    color: var(--ink-muted);
    letter-spacing: 0.005em;
  }

  .curated__pointer {
    grid-area: pointer;
    color: var(--ink-muted);
    font-family: var(--font-mono);
    transform: translateX(0);
    transition:
      transform var(--duration-fast) var(--ease-out-quart),
      color var(--duration-fast) var(--ease-out-quart);
  }

  .curated__pick-title {
    grid-area: title;
    font-family: var(--font-display);
    font-weight: 600;
    font-size: var(--text-body);
    line-height: 1.3;
    transition: color var(--duration-fast) var(--ease-out-quart);
  }

  .curated__pick-meta {
    grid-area: meta;
    font-family: var(--font-mono);
    font-size: var(--text-meta);
    color: var(--ink-muted);
  }

  @media (max-width: 640px) {
    .curated__link {
      grid-template-columns: auto 1fr;
      grid-template-areas:
        'framing framing'
        'pointer title'
        '. meta';
      row-gap: 0.25rem;
      column-gap: var(--space-xs);
    }
    .curated__framing {
      margin-bottom: 0.25rem;
    }
  }
</style>
