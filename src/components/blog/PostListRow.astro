---
// ABOUTME: A row on /blog/ — hero left + text right (desktop), hero on top + text below (mobile).
// ABOUTME: Reuses the three-tier hero resolver; falls back to the Sigil SVG when no asset is committed.

import { Image } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';
import { resolveHero } from '../../lib/heroResolver';
import { generateHeroFallbackSvg } from '../../lib/heroFallback';

interface Props {
  post: CollectionEntry<'blog'>;
  /** Position in the list. Drives the stagger reveal. */
  index: number;
}

const { post, index } = Astro.props;

const date = new Date(post.data.date);
const year = String(date.getFullYear());
const month = String(date.getMonth() + 1).padStart(2, '0');
const titleSlug = post.id.replace(/^\d{4}-\d{2}-/, '').replace(/\.mdx?$/, '');
const href = `/${year}/${month}/${titleSlug}/`;

const resolution = resolveHero({
  slug: titleSlug,
  title: post.data.title,
  category: post.data.category,
  featuredImage: post.data.featured_image,
  featuredImageAlt: post.data.featured_image_alt,
});

const fallbackSvg =
  resolution.kind === 'fallback'
    ? generateHeroFallbackSvg({
        title: resolution.title,
        category: resolution.category,
        seed: resolution.seed,
        variant: 'compact',
      })
    : null;

const wordCount = (post.body ?? '').split(/\s+/).filter(Boolean).length;
const readingMinutes = Math.max(1, Math.ceil(wordCount / 220));

const dateFormat = new Intl.DateTimeFormat('en-GB', {
  year: 'numeric',
  month: 'short',
  day: '2-digit',
});
---

<article class="post-row" style={`--i: ${index}`}>
  <a class="post-row__link" href={href}>
    <figure
      class={`post-row__hero ${resolution.kind === 'fallback' ? 'post-row__hero--fallback' : 'post-row__hero--image'}`}
      aria-hidden="true"
    >
      {
        resolution.kind === 'image' ? (
          <Image
            src={resolution.image}
            alt=""
            widths={[280, 480, 640]}
            sizes="(max-width: 720px) 100vw, 280px"
            loading="lazy"
            decoding="async"
          />
        ) : (
          <Fragment set:html={fallbackSvg} />
        )
      }
    </figure>

    <div class="post-row__text">
      <p class="post-row__kicker tabular">{post.data.category}</p>
      <h2 class="post-row__title">{post.data.title}</h2>
      {post.data.description && <p class="post-row__lede">{post.data.description}</p>}
      <p class="post-row__meta tabular">
        <time datetime={date.toISOString()}>{dateFormat.format(date)}</time>
        <span class="post-row__sep" aria-hidden="true">·</span>
        <span>{readingMinutes} min</span>
      </p>
    </div>
  </a>
</article>

<style>
  .post-row {
    position: relative;
  }

  .post-row__link {
    display: grid;
    grid-template-columns: 17.5rem 1fr;
    column-gap: var(--space-lg);
    align-items: start;
    padding: var(--space-md) 0;
    color: var(--ink);
    text-decoration: none;
    outline: none;
    border-radius: var(--radius-md);
    transition: transform var(--duration-fast) var(--ease-out-quart);
  }

  .post-row__link:focus-visible {
    outline: 2px solid var(--accent);
    outline-offset: 0.5rem;
  }

  .post-row__hero {
    margin: 0;
    width: 100%;
    aspect-ratio: 3 / 2;
    border-radius: var(--radius-md);
    overflow: hidden;
    background: var(--surface);
    transition:
      transform var(--duration-base) var(--ease-out-quart),
      box-shadow var(--duration-base) var(--ease-out-quart);
  }

  .post-row__hero :global(img),
  .post-row__hero :global(svg) {
    display: block;
    width: 100%;
    height: 100%;
  }

  .post-row__hero--image :global(img) {
    object-fit: cover;
  }

  .post-row__hero--fallback :global(svg) {
    object-fit: contain;
  }

  .post-row__text {
    min-width: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-xs);
    padding-top: 0.25rem;
  }

  .post-row__kicker {
    font-family: var(--font-mono);
    font-size: var(--text-meta);
    color: var(--ink-muted);
    margin: 0;
    letter-spacing: 0.04em;
    text-transform: lowercase;
  }

  .post-row__title {
    font-family: var(--font-display);
    font-size: var(--text-h3);
    font-weight: 700;
    line-height: 1.15;
    letter-spacing: -0.02em;
    color: var(--ink);
    margin: 0;
    text-wrap: balance;
    transition: color var(--duration-fast) var(--ease-out-quart);
  }

  .post-row__lede {
    font-family: var(--font-prose);
    font-size: var(--text-body);
    line-height: 1.5;
    color: var(--ink-muted);
    margin: 0;
    text-wrap: pretty;
    max-width: 56ch;
  }

  .post-row__meta {
    display: inline-flex;
    align-items: baseline;
    gap: 0.55ch;
    font-family: var(--font-mono);
    font-size: var(--text-meta);
    color: var(--ink-muted);
    margin: 0;
    margin-top: var(--space-2xs);
  }

  .post-row__sep {
    opacity: 0.55;
  }

  /* Hover: lift the hero, shift the title to the accent. The hero IS the
     visible affordance — it's the only meaningful image-rich element on
     the page, so motion lands there. */
  .post-row__link:hover .post-row__hero,
  .post-row__link:focus-visible .post-row__hero {
    transform: translateY(-2px);
    box-shadow: 0 8px 24px -12px color-mix(in oklab, var(--ink) 24%, transparent);
  }

  .post-row__link:hover .post-row__title,
  .post-row__link:focus-visible .post-row__title {
    color: var(--accent-ink);
  }

  @media (max-width: 720px) {
    .post-row__link {
      grid-template-columns: 1fr;
      row-gap: var(--space-sm);
      padding: var(--space-sm) 0;
    }

    .post-row__hero {
      max-width: 100%;
    }

    .post-row__title {
      font-size: var(--text-h3);
    }

    .post-row__lede {
      font-size: var(--text-small);
    }
  }

  /* Stagger reveal: cascade top-down, 40ms per row. Caps at row 10 so the
     last entries don't wait half a second to fade in. */
  @media (prefers-reduced-motion: no-preference) {
    .post-row {
      opacity: 0;
      transform: translateY(8px);
      transition:
        opacity var(--duration-slow) var(--ease-out-quart),
        transform var(--duration-slow) var(--ease-out-quart);
      transition-delay: calc(min(var(--i, 0), 10) * 40ms);
    }

    :global(.reveal-in) .post-row,
    :global(.no-js) .post-row {
      opacity: 1;
      transform: none;
    }
  }
</style>
